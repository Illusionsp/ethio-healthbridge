# ---------------------------------------------------------------------------
# Ethio-HealthBridge backend environment variables.
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
# ---------------------------------------------------------------------------

# Required: Google Gemini API key (used by STT, RAG, vision, and embeddings).
# Create one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Required: Same key under the name LlamaIndex's Gemini integration looks for.
# In practice, set this to the same value as GEMINI_API_KEY.
GOOGLE_API_KEY=

# Optional: Telegram bot credentials for the doctor-alert dispatcher.
#
# Setup (see README "Setting Up the Doctors' Telegram Group" for full steps):
#   1. Create a bot via @BotFather; the token goes into TELEGRAM_BOT_TOKEN.
#   2. Create a Telegram group for the hospital's on-call doctors and add the
#      bot to it.
#   3. Send any message in the group, then call
#      https://api.telegram.org/bot<TOKEN>/getUpdates and copy the numeric
#      "chat":{"id":-100...} value into TELEGRAM_DOCTOR_CHAT_ID. Group IDs
#      always start with "-100".
#
# If either value is missing, Telegram alerts are disabled silently and the
# rest of the system continues to work.
TELEGRAM_BOT_TOKEN=
TELEGRAM_DOCTOR_CHAT_ID=
# Legacy alias for TELEGRAM_DOCTOR_CHAT_ID (either variable is accepted).
# TELEGRAM_CHAT_ID=
